{
  "$schema": "../../Schemas/cassette.schema.json",
  "version": "2.0",
  "fileType": "cassette",

  "model": "FOUP-25-200",
  "standard": "SEMI E47.1",
  "description": "25-slot Front Opening Unified Pod for 200mm wafers — SEMI standard geometry",

  "units": {
    "length": "mm",
    "time": "ms"
  },

  "geometry": {
    "slotCount": 25,
    "pitch": 6.35,
    "offset": 3.175,
    "stroke": 5.0,
    "slotHeight": 0.8,
    "waferDiameter": 200,
    "waferThickness": 0.725,
    "description": "pitch = center-to-center between slots, offset = Z from cassette base to slot 1 center, stroke = Z lift to clear shelf, slotHeight = shelf thickness"
